# Database
POSTGRES_USER=2hjs
POSTGRES_PASSWORD=2hjs_secret
POSTGRES_DB=2hjs_tracker
DATABASE_URL="postgresql://2hjs:2hjs_secret@localhost:5432/2hjs_tracker"

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/google/callback

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001

# Auth (NEW - generate a secure random string at least 32 chars)
JWT_SECRET=your-jwt-secret-key-at-least-32-characters-long
JWT_EXPIRY=7d
APP_URL=http://localhost:5173

# Email Service (NEW - get from resend.com)
RESEND_API_KEY=re_your-resend-api-key
